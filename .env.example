# AfricaKai Platform — Environment Variables
# Copy this to .env.local and fill in your values
# DO NOT commit .env.local to GitHub

# ─── Supabase ─────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Anthropic (Claude AI) ────────────────────────────────────────────────────
# Note: In production, API calls go through your backend, NOT the frontend
# Never expose your Anthropic API key in client-side code
VITE_ANTHROPIC_API_KEY=your-anthropic-api-key

# ─── Email (Resend) ───────────────────────────────────────────────────────────
VITE_RESEND_API_KEY=your-resend-api-key
VITE_EMAIL_FROM_DOMAIN=africakai.co.za

# ─── App ──────────────────────────────────────────────────────────────────────
VITE_APP_URL=https://platform.africakai.co.za
VITE_APP_NAME=AfricaKai Platform
